# OpenBotX Environment Variables
# Copy this file to .env and fill in your values

# LLM API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id-here

# PostgreSQL (optional, if using postgres instead of sqlite)
POSTGRES_HOST=localhost
POSTGRES_USER=openbotx
POSTGRES_PASSWORD=your-password-here

# AWS S3 (optional, if using s3 storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your-access-key-here
AWS_SECRET_KEY=your-secret-key-here
S3_BUCKET=your-bucket-name-here

# OpenAI TTS (uses OPENAI_API_KEY above)
